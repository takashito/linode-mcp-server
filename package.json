{
  "name": "@takashito/linode-mcp-server",
  "version": "0.2.5",
  "description": "MCP server for Linode API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": false,
  "files": [
    "dist/"
  ],
  "bin": {
    "linode-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint .",
    "inspect": "tsc && npx @modelcontextprotocol/inspector node dist/index.js",
    "build-image": "docker build -t takashito/linode-mcp-server:latest .",
    "start-docker": "docker run --rm -p 8080:8080 --name linode-mcp-server takashito/linode-mcp-server:latest"
  },
  "keywords": [
    "linode",
    "mcp",
    "claude",
    "anthropic",
    "ai",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.9.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "fastmcp": "^1.27.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "mcp-client": "^1.12.4"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.20.0",
    "minimatch": ">=3.1.4",
    "brace-expansion": ">=1.1.13"
  }
}
